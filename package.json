{
  "name": "app",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "npm run tokens && vite",
    "build": "npm run tokens && tsc -b && vite build",
    "tokens": "style-dictionary build --config style-dictionary.config.mjs && prettier --write src/styles/tokens.css src/styles/tokens.ts figma-tokens.json",
    "tokens:validate": "node scripts/validate-tokens.mjs",
    "tokens:check": "node scripts/check-tokens-fresh.mjs",
    "test:tokens": "node --test scripts/validate-tokens.test.mjs",
    "figma:typecheck": "tsc -p tsconfig.figma.json",
    "code-connect:check": "node scripts/check-code-connect.mjs",
    "test:code-connect": "node --test scripts/check-code-connect.test.mjs",
    "test:figma-snapshot": "node --test scripts/figma-snapshot.test.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -b --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,cjs,mjs,json,css,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,cjs,mjs,json,css,md,yml,yaml}\"",
    "commitlint": "commitlint",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:visual": "playwright test -c playwright.visual.config.ts",
    "test:visual:update": "playwright test -c playwright.visual.config.ts --update-snapshots",
    "test:a11y": "playwright test -c playwright.a11y.config.ts",
    "test:packages": "npm run test:packages:sdk-ts && npm run test:packages:mcp-server",
    "test:packages:sdk-ts": "npm ci --prefix packages/sdk-ts && npm run build --prefix packages/sdk-ts && npm test --prefix packages/sdk-ts",
    "test:packages:mcp-server": "npm ci --prefix packages/mcp-server && npm run build --prefix packages/mcp-server && npm test --prefix packages/mcp-server",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-positioner": "^2.3.2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@commitlint/cli": "21.2.0",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/js": "^10.0.1",
    "@figma/code-connect": "^1.4.9",
    "@playwright/test": "^1.55.0",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "ajv": "^8.20.0",
    "eslint": "^10.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^26.1.0",
    "lefthook": "2.1.9",
    "prettier": "3.9.4",
    "style-dictionary": "^5.5.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
