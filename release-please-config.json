{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "bootstrap-sha": "db76ab1",
  "include-component-in-tag": true,
  "separate-pull-requests": false,
  "pull-request-title-pattern": "chore(release): release ${version}",
  "packages": {
    ".": {
      "release-type": "node",
      "component": "chaos-scheduler",
      "package-name": "chaos-scheduler",
      "changelog-path": "CHANGELOG.md",
      "changelog-sections": [
        { "type": "feat", "section": "Features" },
        { "type": "fix", "section": "Bug Fixes" },
        { "type": "perf", "section": "Performance" },
        { "type": "refactor", "section": "Refactors" },
        { "type": "docs", "section": "Documentation" },
        { "type": "build", "section": "Build System" },
        { "type": "ci", "section": "Continuous Integration", "hidden": true },
        { "type": "chore", "section": "Miscellaneous", "hidden": true }
      ],
      "extra-files": [
        {
          "type": "json",
          "path": "src-tauri/tauri.conf.json",
          "jsonpath": "$.version"
        },
        {
          "type": "generic",
          "path": "src/lib/branding.ts"
        }
      ]
    },
    "src-tauri": {
      "release-type": "rust",
      "component": "chaos-scheduler-tauri",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/sdk-ts": {
      "release-type": "node",
      "component": "sdk-ts",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/mcp-server": {
      "release-type": "node",
      "component": "mcp-server",
      "changelog-path": "CHANGELOG.md"
    }
  },
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "chaos-scheduler-desktop",
      "components": ["chaos-scheduler", "chaos-scheduler-tauri"]
    }
  ]
}
