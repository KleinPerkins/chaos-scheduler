{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chaos Scheduler",
  "version": "1.0.4",
  "identifier": "com.chaosscheduler.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Chaos Scheduler",
        "width": 960,
        "height": 680,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:*; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "signingIdentity": null,
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:scheduler.db"
      ]
    },
    "updater": {
      "endpoints": [
        "https://github.com/KleinPerkins/chaos-scheduler/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCODUzMzgxQTAyMEI3MDAKUldRQXR5Q2dnVE9GZTBnK1pYa3g0VldyZWpTWThrdHF0S1ExcmlNNXV6T1p6T0VwcWY1RzY0N28K"
    }
  }
}
