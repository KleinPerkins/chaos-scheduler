{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chaos Scheduler",
  "version": "0.2.0",
  "identifier": "com.chaosscheduler.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Chaos Scheduler",
        "width": 960,
        "height": 680,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "signingIdentity": null,
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:scheduler.db"
      ]
    },
    "updater": {
      "endpoints": [
        "https://github.com/KleinPerkins/chaos-scheduler/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_MINISIGN_PUBLIC_KEY"
    }
  }
}
